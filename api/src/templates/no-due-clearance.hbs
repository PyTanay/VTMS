<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    body { font-family: Arial, sans-serif; background: #f4f4f4; margin: 0; padding: 0; }
    .container { max-width: 600px; margin: 24px auto; background: #ffffff; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,0.1); }
    .header { background: linear-gradient(135deg, #1a73e8, #0d47a1); padding: 24px; text-align: center; }
    .header h1 { margin: 0; color: #ffffff; font-size: 20px; }
    .body { padding: 24px; color: #333; line-height: 1.6; }
    .badge { display: inline-block; padding: 4px 12px; border-radius: 4px; font-size: 13px; font-weight: 600; }
    .badge.cleared { background: #e8f5e9; color: #2e7d32; }
    .badge.pending { background: #fff3e0; color: #e65100; }
    .footer { padding: 16px 24px; background: #f9f9f9; font-size: 12px; color: #888; text-align: center; }
    table.details { width: 100%; border-collapse: collapse; margin: 16px 0; }
    table.details td { padding: 8px; border-bottom: 1px solid #eee; }
    table.details td:first-child { color: #888; width: 40%; }
    table.details td:last-child { font-weight: 600; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>No Dues Clearance</h1>
    </div>
    <div class="body">
      <p>Dear <strong>{{studentName}}</strong>,</p>
      {{#if isCleared}}
      <p>Your no-due clearance has been completed. All outstanding items have been cleared.</p>
      {{else}}
      <p>Your no-due clearance form has been initiated. Please check with the respective departments.</p>
      {{/if}}
      <table class="details">
        <tr><td>Application No</td><td>{{applicationNo}}</td></tr>
        <tr><td>No Due Ref</td><td>{{noDueRef}}</td></tr>
        <tr><td>Status</td><td><span class="badge {{#if isCleared}}cleared{{else}}pending{{/if}}">{{status}}</span></td></tr>
        <tr><td>Cleared On</td><td>{{clearedOn}}</td></tr>
      </table>
    </div>
    <div class="footer">
      &copy; 2026 GNFC Ltd — Vocational Training Management System
    </div>
  </div>
</body>
</html>