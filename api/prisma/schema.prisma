generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Application {
  id                       Int                       @id @default(autoincrement())
  application_no           String                    @unique
  applicant_type           ApplicantType
  application_date         DateTime                  @default(now())
  status                   ApplicationStatus         @default(DRAFT)
  student_surname          String
  student_name             String
  student_father_name      String
  son_daughter             Boolean                   @default(false)
  relation                 String?
  student_email            String
  student_mobile           String
  presently_pursuing       Boolean                   @default(true)
  training_compulsory      Boolean                   @default(true)
  part_of_curriculum       Boolean                   @default(true)
  full_time_course         Boolean                   @default(true)
  past_training            Boolean                   @default(false)
  categoryId               Int
  branchId                 Int
  year_of_study            Int
  semester                 Int
  collegeId                Int
  college_pincode          String?
  college_website          String?
  college_hod_name         String?
  college_hod_email        String?
  college_letter_ref       String?
  college_letter_date      DateTime?
  requested_from           DateTime
  requested_to             DateTime
  approved_from            DateTime?
  approved_to              DateTime?
  recommending_employee_id Int?
  reference_details        String?
  scrutiny_in_charge_id    Int?
  scrutiny_date            DateTime?
  scrutiny_remarks         String?
  permission_letter_ref    String?
  permission_letter_date   DateTime?
  posting_department_id    Int?
  joining_date             DateTime?
  gate_pass_no             String?
  gate_pass_valid_up_to    DateTime?
  behavioral_rating        String?
  progress_rating          String?
  actual_completion_date   DateTime?
  report_submission_date   DateTime?
  certificate_ref          String?
  certificate_issue_date   DateTime?
  no_due_ref               String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  archived                 Boolean                   @default(false)
  branch                   Branch                    @relation(fields: [branchId], references: [id])
  category                 Category                  @relation(fields: [categoryId], references: [id])
  college                  College                   @relation(fields: [collegeId], references: [id])
  department               Department?               @relation(fields: [posting_department_id], references: [id])
  employee                 Employee?                 @relation(fields: [recommending_employee_id], references: [id])
  biodata_form             BiodataForm?
  certificates             Certificate[]
  comments                 Comment[]
  document_verifications   DocumentVerification[]
  no_due_form              NoDueForm?
  posting_letter_students  PostingLetterStudent[]
  @@map("applications")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  userId      Int?
  action      String
  entity_name String
  entity_id   Int
  old_value   String?
  new_value   String?
  timestamp   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id])
  @@map("audit_logs")
}

model BiodataAcademic {
  id               Int           @id @default(autoincrement())
  biodataId        Int
  course_name      String
  board_university String
  passing_year     Int
  percentage_cgpa  Float
  biodata_form     BiodataForm @relation(fields: [biodataId], references: [id], onDelete: Cascade)
  @@map("biodata_academics")
}

model BiodataExtracurricular {
  id            Int           @id @default(autoincrement())
  biodataId     Int
  activity_name String
  achievements  String?
  biodata_form  BiodataForm @relation(fields: [biodataId], references: [id], onDelete: Cascade)
  @@map("biodata_extracurriculars")
}

model BiodataFamilyMember {
  id            Int           @id @default(autoincrement())
  biodataId     Int
  member_name   String
  relationship  String
  age           Int
  occupation    String?
  contact_no    String?
  biodata_form  BiodataForm @relation(fields: [biodataId], references: [id], onDelete: Cascade)
  @@map("biodata_family_members")
}

model BiodataForm {
  id                       Int                        @id @default(autoincrement())
  applicationId            Int                        @unique
  local_address            String
  permanent_address        String
  caste                    String?
  height_cm                Float?
  weight_kg                Float?
  blood_group              String?
  physically_challenged    Boolean                    @default(false)
  challenge_details        String?
  photo_path               String?
  student_declaration      Boolean                    @default(true)
  student_signature_path   String?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                  @updatedAt
  application              Application               @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  biodata_academics        BiodataAcademic[]
  biodata_extracurriculars BiodataExtracurricular[]
  biodata_family_members   BiodataFamilyMember[]
  biodata_gnfc_relatives   BiodataGnfcRelative[]
  biodata_other_trainings  BiodataOtherTraining[]
  biodata_postings         BiodataPosting[]
  biodata_sports           BiodataSport[]
  @@map("biodata_forms")
}

model BiodataGnfcRelative {
  id            Int           @id @default(autoincrement())
  biodataId     Int
  relative_name String
  relationship  String
  department    String
  employee_no   String
  biodata_form  BiodataForm @relation(fields: [biodataId], references: [id], onDelete: Cascade)
  @@map("biodata_gnfc_relatives")
}

model BiodataOtherTraining {
  id              Int           @id @default(autoincrement())
  biodataId       Int
  institute_name  String
  course_name     String
  training_period String
  remarks         String?
  biodata_form    BiodataForm @relation(fields: [biodataId], references: [id], onDelete: Cascade)
  @@map("biodata_other_trainings")
}

model BiodataPosting {
  id            Int           @id @default(autoincrement())
  biodataId     Int
  department    String
  in_charge     String
  posting_from  DateTime
  posting_to    DateTime
  remarks       String?
  biodata_form  BiodataForm @relation(fields: [biodataId], references: [id], onDelete: Cascade)
  @@map("biodata_postings")
}

model BiodataSport {
  id                     Int           @id @default(autoincrement())
  biodataId              Int
  game_name              String
  level_of_participation String
  achievements           String?
  biodata_form           BiodataForm @relation(fields: [biodataId], references: [id], onDelete: Cascade)
  @@map("biodata_sports")
}

model Branch {
  id           Int            @id @default(autoincrement())
  branch_name  String         @unique
  applications Application[]
  @@map("branches")
}

model Category {
  id           Int            @id @default(autoincrement())
  name         String         @unique
  applications Application[]
  @@map("categories")
}

model Certificate {
  id                       Int          @id @default(autoincrement())
  certificate_ref          String       @unique
  applicationId            Int
  behavioral_rating          String
  progress_rating          String
  actual_completion_date DateTime
  report_submission_date   DateTime
  special_issue_remarks  String?
  is_duplicate           Boolean      @default(false)
  duplicate_approved_by  String?
  duplicate_reason       String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime                  @updatedAt
  issued_at              DateTime?
  application            Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  @@map("certificates")
}

model City {
  id       Int      @id @default(autoincrement())
  name     String
  talukaId Int?
  taluka   Taluka? @relation(fields: [talukaId], references: [id])
  @@map("cities")
}

model College {
  id           Int            @id @default(autoincrement())
  college_name String
  place        String
  applications Application[]
  @@map("colleges")
}

model Comment {
  id            Int          @id @default(autoincrement())
  applicationId Int
  userId        Int
  content       String
  parentId      Int?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime                  @updatedAt
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id])
  @@map("comments")
}

model Department {
  id              Int            @id @default(autoincrement())
  department_name String         @unique
  createdAt       DateTime       @default(now())
  applications    Application[]
  @@map("departments")
}

model District {
  id      Int       @id @default(autoincrement())
  name    String
  stateId Int
  state   State     @relation(fields: [stateId], references: [id])
  talukas Taluka[]
  @@map("districts")
}

model DocumentVerification {
  id             Int          @id @default(autoincrement())
  applicationId  Int
  doc_type       String
  file_path      String
  verified       Boolean      @default(false)
  verified_by_id Int?
  verified_at    DateTime?
  remarks        String?
  application    Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  user           User?       @relation(fields: [verified_by_id], references: [id])
  @@map("document_verifications")
}

model EmailConfig {
  id        Int      @id @default(autoincrement())
  type      String   @unique
  enabled   Boolean  @default(true)
  updatedAt DateTime                  @updatedAt
  dev_mode  Boolean  @default(false)
  @@map("email_configs")
}

model EmailLog {
  id            Int      @id @default(autoincrement())
  to_email      String
  subject       String
  body          String
  sent_status   Boolean  @default(false)
  sent_at       DateTime @default(now())
  error_message String?
  @@map("email_logs")
}

model Employee {
  id             Int            @id @default(autoincrement())
  employee_no    String         @unique
  name           String
  department     String
  email          String
  designation    String
  active         Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime                  @updatedAt
  receive_emails Boolean        @default(true)
  contact_no     String?
  status         String?
  applications   Application[]
  user           User?
  @@map("employees")
}

model FinancialYear {
  id          Int     @id @default(autoincrement())
  year_string String  @unique
  active      Boolean @default(false)
  @@map("financial_years")
}

model NoDueClearanceLine {
  id            Int          @id @default(autoincrement())
  noDueId       Int
  item_name     String
  cleared       Boolean      @default(false)
  cleared_by_id Int?
  cleared_at    DateTime?
  remarks       String?
  user          User?        @relation(fields: [cleared_by_id], references: [id])
  no_due_form   NoDueForm @relation(fields: [noDueId], references: [id], onDelete: Cascade)
  @@map("no_due_clearance_lines")
}

model NoDueForm {
  id                     Int                      @id @default(autoincrement())
  no_due_ref             String                   @unique
  applicationId          Int                      @unique
  status                 String                   @default("PENDING")
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                  @updatedAt
  no_due_clearance_lines NoDueClearanceLine[]
  application            Application             @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  @@map("no_due_forms")
}

model PostingLetterStudent {
  id              Int             @id @default(autoincrement())
  postingLetterId Int
  applicationId   Int
  approved_days   String?
  application     Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  posting_letter  PostingLetter @relation(fields: [postingLetterId], references: [id], onDelete: Cascade)
  @@map("posting_letter_students")
}

model PostingLetter {
  id                      Int                       @id @default(autoincrement())
  ref_no                  String                    @unique
  date                    DateTime                  @default(now())
  qualification_branch    String
  college_short_name      String
  college_place           String
  posting_department      String
  to_report_to            String
  reporting_officer_email String
  selected_weekdays       String
  training_in_charge      String
  department_head         String
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  posting_letter_students PostingLetterStudent[]
  @@map("posting_letters")
}

model RoleMappingLog {
  id          Int      @id @default(autoincrement())
  action      String
  designation String?
  role        String?
  result      String?
  userId      Int?
  createdAt   DateTime @default(now())
  @@map("role_mapping_logs")
}

model RoleMapping {
  id          Int      @id @default(autoincrement())
  designation String   @unique
  role        Role
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime                  @updatedAt
  @@map("role_mappings")
}

model SamvadSyncLog {
  id        Int      @id @default(autoincrement())
  level     String
  message   String
  details   String?
  syncRunId String?
  createdAt DateTime @default(now())
  @@map("samvad_sync_logs")
}

model SiteVisit {
  id        Int      @id @default(autoincrement())
  path      String
  userAgent String?
  ipAddress String?
  userId    Int?
  createdAt DateTime @default(now())
  @@map("site_visits")
}

model State {
  id        Int         @id @default(autoincrement())
  name      String      @unique
  districts District[]
  @@map("states")
}

model Taluka {
  id         Int       @id @default(autoincrement())
  name       String
  districtId Int
  cities     City[]
  district   District @relation(fields: [districtId], references: [id])
  @@map("talukas")
}

model User {
  id                       Int                      @id @default(autoincrement())
  username                 String                   @unique
  email                    String                   @unique
  password                 String
  role                     Role                     @default(APPLICANT)
  employeeId               Int?                     @unique
  designation              String?
  emailPreferences         Json                     @default("{}")
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                  @updatedAt
  active                   Boolean                  @default(true)
  suspended                Boolean                  @default(false)
  audit_logs               AuditLog[]
  comments                 Comment[]
  document_verifications   DocumentVerification[]
  no_due_clearance_lines   NoDueClearanceLine[]
  employee                 Employee?                @relation(fields: [employeeId], references: [id])
  @@map("users")
}

enum ApplicantType {
  EMPLOYEE_WARD
  OTHER_REFERENCE
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  PENDING_APPROVAL
  APPROVED
  REJECTED
  RECEIVED_BY_TC
  SCRUTINIZED
  ASSIGNED_TO_INCHARGE
  PERMISSION_LETTER_SENT
  JOINING_PENDING
  DOCUMENTS_VERIFIED
  BIODATA_COMPLETED
  GATE_PASS_CREATED
  POSTED
  TRAINING_ACTIVE
  NO_DUES_PENDING
  REPORT_SUBMITTED
  CERTIFICATE_READY
  CERTIFICATE_ISSUED
  TRAINING_COMPLETED
  CLOSED
}

enum Role {
  ADMIN
  RECOMMENDING_EMPLOYEE
  TRAINING_CENTER_SECTION_HEAD
  TRAINING_IN_CHARGE
  ED_GM_APPROVER
  APPLICANT
}