# ── Database ──
DATABASE_URL=postgresql://user:pass@localhost:5432/vtms_db

# ── Authentication ──
JWT_SECRET=change-me-to-a-random-secret
JWT_REFRESH_SECRET=change-me-to-a-random-refresh-secret
JWT_EXPIRES_IN=7d

# ── Server ──
PORT=3000
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:3000
NODE_ENV=development

# ── SMTP (for nodemailer email delivery) ──
SMTP_HOST=smtp.gnfc.in
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=vtms@gnfc.in
SMTP_PASS=your-smtp-password

# ── Email Settings ──
# redirect all emails to DEV_EMAIL when EMAIL_REDIRECT_MODE=true
DEV_EMAIL=tjdesai@gnfc.in
EMAIL_REDIRECT_MODE=true
# master switch to enable/disable all email sending
EMAIL_ENABLED=true

# ── Optional: Redis (for bee-queue job queue) ──
REDIS_URL=redis://localhost:6379

# ── SAMVAD Scraper (for employee sync) ──
SAMVAD_URL=https://samvad.gnfc.in
SAMVAD_USERNAME=your-samvad-username
SAMVAD_PASSWORD=your-samvad-password
SAMVAD_SYNC_CRON=0 2 * * *

# ── Employee defaults ──
EMPLOYEE_DEFAULT_PASSWORD=gnfc123
CREATE_EMPLOYEE_USERS=true
